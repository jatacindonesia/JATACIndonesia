rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read and write to site config
    match /config/site {
      allow read: if true;
      allow write: if true;
    }

    // Allow read and write to members
    match /members/{memberId} {
      allow read: if true;
      allow write: if true;
    }

    // Allow read and write to learning sessions
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if true;
    }

    // Allow read and write to articles
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }

    // Allow read and write to gallery items
    match /gallery/{galleryId} {
      allow read: if true;
      allow write: if true;
    }

    // Allow read and write to LMS modules
    match /lmsModules/{moduleId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
